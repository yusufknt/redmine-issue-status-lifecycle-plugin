<h2>Status Lifecycle</h2>

<% available_users = Array(@available_users) %>
<% available_categories = Array(@available_categories) %>
<% user_stats = Array(@user_stats) %>
<% category_stats = Array(@category_stats) %>
<% status_stats = Array(@status_stats) %>
<% issues_data = Array(@issues_data) %>

<%= form_with url: project_issue_status_lifecycle_path(@project), method: :get, local: true do %>
  <fieldset style="margin-bottom: 15px;">
    <legend><strong>Filtreler</strong></legend>

    <label for="issue_id">Issue No:</label>
    <%= text_field_tag :issue_id, params[:issue_id], id: 'issue_id', placeholder: 'Orn: 123', style: 'margin-right:10px;' %>

    <label for="user">Kullanıcı:</label>
    <%= select_tag :user, options_for_select([['Tümü', '']] + available_users.map { |u| [u, u] }, params[:user]), id: 'user', style: 'margin-right:10px;' %>

    <label for="category">Kategori:</label>
    <%= select_tag :category, options_for_select([['Tümü', '']] + available_categories.map { |c| [c, c] }, params[:category]), id: 'category', style: 'margin-right:10px;' %>

    <%= submit_tag 'Filtrele' %>
    <%= link_to 'Temizle', project_issue_status_lifecycle_path(@project), style: 'margin-left:8px;' %>
    <%= link_to 'CSV Export', project_issue_status_lifecycle_path(@project, request.query_parameters.merge(format: :csv)), style: 'margin-left:12px;' %>
  </fieldset>
<% end %>

<h3>Kullanıcıya Göre Toplam Süre</h3>

<table border="1" cellpadding="5">
  <tr>
    <th>Kullanıcı</th>
    <th>Toplam Süre</th>
  </tr>

  <% user_stats.each do |user_stat| %>
    <tr>
      <td><%= user_stat[:user] %></td>
      <td><%= user_stat[:total_text] %></td>
    </tr>
  <% end %>
</table>

<canvas id="userChart" width="400" height="180"></canvas>

<br>

<h3>Kategoriye Göre Toplam Süre</h3>

<table border="1" cellpadding="5">
  <tr>
    <th>Kategori</th>
    <th>Toplam Süre</th>
  </tr>

  <% category_stats.each do |category_stat| %>
    <tr>
      <td><%= category_stat[:category] %></td>
      <td><%= category_stat[:total_text] %></td>
    </tr>
  <% end %>
</table>

<canvas id="categoryChart" width="400" height="180"></canvas>

<br>

<h3>Status'e Gore Toplam Sure</h3>

<table border="1" cellpadding="5">
  <tr>
    <th>Status</th>
    <th>Toplam Sure</th>
  </tr>

  <% status_stats.each do |status_stat| %>
    <tr>
      <td><%= status_stat[:status] %></td>
      <td><%= status_stat[:total_text] %></td>
    </tr>
  <% end %>
</table>

<canvas id="statusChart" width="400" height="180"></canvas>

<br>

<h3>Tüm Durum Geçişleri</h3>

<p>Başlıklara tıklayarak sıralama yapabilirsiniz.</p>

<table id="lifecycle-table" border="1" cellpadding="5">
  <thead>
    <tr>
      <th onclick="sortTable(0, 'number')">İş No</th>
      <th onclick="sortTable(1, 'text')">İş Başlığı</th>
      <th onclick="sortTable(2, 'text')">Kategori</th>
      <th onclick="sortTable(3, 'text')">From</th>
      <th onclick="sortTable(4, 'text')">To</th>
      <th onclick="sortTable(5, 'number')">Süre</th>
      <th onclick="sortTable(6, 'text')">Kullanıcı</th>
      <th onclick="sortTable(7, 'text')">Değişim Zamanı</th>
    </tr>
  </thead>

  <tbody>
    <% issues_data.each do |issue| %>
      <% issue[:history].each do |h| %>
        <tr>
          <td><%= issue[:id] %></td>
          <td><%= issue[:subject] %></td>
          <td><%= issue[:category] %></td>
          <td><%= h[:from] %></td>
          <td><%= h[:to] %></td>
          <td data-sort="<%= h[:duration].to_i %>"><%= h[:duration_text] %></td>
          <td><%= h[:user] %></td>
          <td><%= h[:changed_at] %></td>
        </tr>
      <% end %>
    <% end %>
  </tbody>
</table>

<br>

<h3>İş Bazlı Detaylar</h3>

<% issues_data.each do |issue| %>
  <details style="border:1px solid #ccc; margin-bottom:15px; padding:10px;">
    <summary style="cursor:pointer;">
      #<%= issue[:id] %> - <%= issue[:subject] %>
      | Kategori: <%= issue[:category] %>
      | Toplam süre: <%= issue[:total_duration_text] %>
    </summary>

    <br>

    <canvas id="issueChart_<%= issue[:id] %>" width="400" height="160"></canvas>

    <br>

    <table border="1" cellpadding="5">
      <tr>
        <th>From</th>
        <th>To</th>
        <th>Süre</th>
        <th>Kullanıcı</th>
        <th>Değişim zamanı</th>
      </tr>

      <% issue[:history].each do |h| %>
        <tr>
          <td><%= h[:from] %></td>
          <td><%= h[:to] %></td>
          <td><%= h[:duration_text] %></td>
          <td><%= h[:user] %></td>
          <td><%= h[:changed_at] %></td>
        </tr>
      <% end %>
    </table>
  </details>
<% end %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  let sortDirections = {};

  function sortTable(columnIndex, type) {
    const table = document.getElementById("lifecycle-table");
    const tbody = table.querySelector("tbody");
    const rows = Array.from(tbody.querySelectorAll("tr"));

    sortDirections[columnIndex] = !sortDirections[columnIndex];
    const ascending = sortDirections[columnIndex];

    rows.sort((a, b) => {
      let aCell = a.children[columnIndex];
      let bCell = b.children[columnIndex];

      let aValue = aCell.dataset.sort || aCell.innerText.trim();
      let bValue = bCell.dataset.sort || bCell.innerText.trim();

      if (type === "number") {
        aValue = Number(aValue);
        bValue = Number(bValue);
      } else {
        aValue = aValue.toLowerCase();
        bValue = bValue.toLowerCase();
      }

      if (aValue < bValue) return ascending ? -1 : 1;
      if (aValue > bValue) return ascending ? 1 : -1;
      return 0;
    });

    rows.forEach(row => tbody.appendChild(row));
  }

  const userLabels = <%= raw user_stats.map { |u| u[:user] }.to_json %>;
  const userData = <%= raw user_stats.map { |u| u[:total].to_i }.to_json %>;

  new Chart(document.getElementById("userChart"), {
    type: "bar",
    data: {
      labels: userLabels,
      datasets: [{
        label: "Kullanıcıya göre toplam süre (saniye)",
        data: userData
      }]
    }
  });

  const categoryLabels = <%= raw category_stats.map { |c| c[:category] }.to_json %>;
  const categoryData = <%= raw category_stats.map { |c| c[:total].to_i }.to_json %>;

  new Chart(document.getElementById("categoryChart"), {
    type: "bar",
    data: {
      labels: categoryLabels,
      datasets: [{
        label: "Kategoriye göre toplam süre (saniye)",
        data: categoryData
      }]
    }
  });

  <% issues_data.each do |issue| %>
    new Chart(document.getElementById("issueChart_<%= issue[:id] %>"), {
      type: "bar",
      data: {
        labels: <%= raw issue[:history].map { |h| "#{h[:from]} → #{h[:to]}" }.to_json %>,
        datasets: [{
          label: "Issue #<%= issue[:id] %> durum süreleri (saniye)",
          data: <%= raw issue[:history].map { |h| h[:duration].to_i }.to_json %>
        }]
      }
    });
  <% end %>

  const statusLabels = <%= raw status_stats.map { |s| s[:status] }.to_json %>;
  const statusData = <%= raw status_stats.map { |s| s[:total].to_i }.to_json %>;

  new Chart(document.getElementById("statusChart"), {
    type: "bar",
    data: {
      labels: statusLabels,
      datasets: [{
        label: "Status'e gore toplam sure (saniye)",
        data: statusData
      }]
    }
  });
</script>